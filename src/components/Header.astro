---
import { navLinks, siteMetadata } from '../config/site';
import { normalizePathname, withBase } from '../lib/utils';

const currentPath = normalizePathname(Astro.url.pathname);
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href={withBase('/')}>
      <span class="brand-mark">CZ</span>
      <span class="brand-copy">
        <strong>{siteMetadata.siteName}</strong>
        <small>{siteMetadata.tagline}</small>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      {
        navLinks.map((link) => {
          const href = withBase(link.href);
          const isActive =
            normalizePathname(href) === currentPath ||
            (link.href !== '/' && currentPath.startsWith(normalizePathname(href)));

          return (
            <a href={href} class:list={{ active: isActive }}>
              {link.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
